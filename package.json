{
  "version": "14.0.0",
  "type": "module",
  "name": "tsconfig-jaid",
  "license": "MIT",
  "description": "Extendable TypeScript config for my Node projects.",
  "keywords": [
    "config",
    "tsc",
    "tsconfig",
    "typescript",
    "typescript-config",
    "typescript-shareable-config"
  ],
  "author": "Jaid <jaid.jsx@gmail.com> (https://github.com/Jaid)",
  "homepage": "https://github.com/Jaid/tsconfig-jaid",
  "funding": "https://github.com/sponsors/jaid",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaid/tsconfig-jaid"
  },
  "imports": {
    "#/*": "./*",
    "#root/*": "./*",
    "#src/*": "./src/*",
    "#lib/*": "./src/lib/*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "babel-jest": "^30.3.0",
    "babel-preset-jaid": "^17.0.0",
    "eslint": "^10.1.0",
    "eslint-config-jaid": "^25.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "jest": "^30.3.0",
    "map-obj": "^6.0.0",
    "nan": "^2.26.2",
    "rimraf": "^6.1.3",
    "tsconfig-jaid-node": "^12.0.0",
    "webpack": "^5.105.4",
    "webpack-config-jaid": "^17.4.2",
    "yargs": "^18.0.0",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "fse emptyDir out/package && bun scripts/build.ts && bun scripts/build.ts node && bun scripts/build.ts bun && bun scripts/build.ts react",
    "release": "fd --unrestricted --full-path 'dist[\\\\/]package[\\\\/][\\w-]+[\\\\/]production[\\\\/]package.json' --exec bun publish --cwd {//}",
    "test": "bun test --max-concurrency 1 ./test"
  },
  "webpackConfigJaid": "nodeLib"
}
